{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenTracker",
  "version": "0.1.2",
  "identifier": "com.ayan-de.tokentracker",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TokenTracker",
        "width": 380,
        "height": 550,
        "resizable": false,
        "decorations": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
