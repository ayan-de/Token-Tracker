{
  "name": "@thisisayande/tokentracker",
  "version": "0.1.11",
  "private": false,
  "type": "module",
  "description": "AI Provider Quota Monitor - track usage, rate limits, and spend across 40+ LLM providers",
  "bin": {
    "tokentracker": "./bin/tokentracker.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "next build && tauri build",
    "test:npm-launcher": "node --test tests/npm-launcher/launcher.test.mjs",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
